{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Settings perenes do ai-dev-framework. Ajuste no init-project conforme stack.",
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(python scripts/pre_pr_check.py:*)"
    ]
  },
  "_hooks_note": "Ative o hook Stop abaixo para rodar o checklist pré-PR ao final de cada turno da IA. Descomente após validar localmente.",
  "_hooks_example": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python scripts/pre_pr_check.py || true"
          }
        ]
      }
    ]
  }
}
