# Configuration for scripts/pre_pr_check.py.
# Copy to `pre_pr_check.toml` at the project root and adjust.

# Base branch for comparison (usually main or develop)
base = "main"

[release_notes]
# Files where release notes live
paths = ["CHANGELOG.md"]
# If any file in these globs changes, an update to release notes is required
code_globs = ["src/**", "app/**", "lib/**"]

[components]
# If a new file is added under these globs, COMPONENTS.md must be updated
helper_globs = ["**/utils/**", "**/helpers/**", "**/services/**", "**/lib/**"]

[feature_flag]
# Globs for routes/controllers
route_globs = ["**/routers/**", "**/routes/**", "**/controllers/**"]
# Code marker that indicates feature-flag usage
marker = "is_enabled"

# Custom synchronizations — multiple rules allowed.
# When ANY file in `when_any_changes` changes, ALL files in
# `require_all_change` must also change in the same branch.

# Example (from a multi-form scenario):
# [[sync]]
# name = "form-payload-sync"
# when_any_changes = [
#   "app/templates/some_form.html",
# ]
# require_all_change = [
#   "app/models.py",
#   "app/routers/drafts.py",
# ]

# [[sync]]
# name = "tailwind-rebuild"
# when_any_changes = ["app/templates/**/*.html"]
# require_all_change = ["app/static/css/tailwind.css"]
